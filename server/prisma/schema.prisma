// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  agent
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  // Better Auth generates this as a plain String; hand-converted to a Postgres
  // enum for DB-level enforcement. Re-running `better-auth generate` will
  // reset this to String - reapply the enum after regenerating.
  role Role @default(agent)

  assignedTickets Ticket[]

  @@unique([email])
  @@map("user")
}

// A snapshot of a deleted User row. Admin-initiated deletes move the row here
// (rather than flagging it in place) and hard-delete the original User, which
// cascades to that user's Session/Account rows.
model DeletedUser {
  id        String   @id
  name      String
  email     String
  role      Role
  createdAt DateTime
  deletedAt DateTime @default(now())

  @@map("deleted_users")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum TicketStatus {
  open
  resolved
  closed
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

enum TicketCategory {
  general_question
  technical_question
  refund_request
}

enum MessageSender {
  student
  agent
  admin
  ai
}

model Ticket {
  id              Int             @id @default(autoincrement())
  subject         String
  status          TicketStatus    @default(open)
  priority        TicketPriority  @default(medium)
  category        TicketCategory?
  studentEmail    String
  assignedAgentId String?
  assignedAgent   User?           @relation(fields: [assignedAgentId], references: [id])
  messages        TicketMessage[]
  // Set when the auto-resolve worker answers the ticket from the knowledge
  // base and closes it without a human agent - kept out of the main ticket
  // list (GET /api/tickets) since it never needs agent attention.
  resolvedByAi    Boolean         @default(false)
  // Set/cleared whenever status transitions to/from "resolved" (see the AI
  // worker and PATCH /:id/status) - unlike updatedAt, this isn't bumped by
  // unrelated mutations, so it's safe to use for average resolution time.
  resolvedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("tickets")
}

// messageId/inReplyTo hold the inbound email's Message-ID/In-Reply-To
// headers so a later reply can be matched back to this thread; both are
// null for agent/AI-authored messages, which have no email headers.
model TicketMessage {
  id        String        @id @default(uuid())
  ticketId  Int
  ticket    Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    MessageSender
  body      String
  messageId String?       @unique
  inReplyTo String?
  sentAt    DateTime      @default(now())

  @@index([ticketId])
  @@map("ticket_messages")
}
