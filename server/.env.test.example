NODE_ENV=test
PORT=3002

# Separate database so Playwright runs never touch dev/prod data.
DATABASE_URL="postgresql://user:password@localhost:5432/helpdesk_test?schema=public"

# The client's test webServer runs on 5174 (see playwright.config.ts).
CLIENT_URL="http://localhost:5174"

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL="http://localhost:3002"

# Seed admin user for e2e (server/prisma/seed.ts).
ADMIN_EMAIL="admin@test.local"
ADMIN_PASSWORD="test-admin-password-123"
