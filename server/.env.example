# Set to "production" in deployment - required for CLIENT_URL enforcement and secure cookies.
NODE_ENV=development

PORT=3001

DATABASE_URL="postgresql://user:password@localhost:5432/helpdesk?schema=public"

# Better Auth (email/password, database sessions).
# Generate BETTER_AUTH_SECRET with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL="http://localhost:3001"

# Seed admin user (server/prisma/seed.ts).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Gmail API (email intake) - Google Cloud OAuth client for the support inbox.
# Required starting Phase 4 (email intake); optional until then.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Anthropic Claude API - required starting Phase 6 (AI classification/summaries).
ANTHROPIC_API_KEY=
