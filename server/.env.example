GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Anthropic Claude API - required starting Phase 6 (AI classification/summaries).
ANTHROPIC_API_KEY=
