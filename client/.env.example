VITE_API_URL=http://localhost:3001

# Sentry error logging (https://sentry.io - Settings > Projects > <project> > Client Keys (DSN)).
# Optional - leave blank to disable error reporting locally.
VITE_SENTRY_DSN=
# Environment tag attached to Sentry events. Falls back to Vite's MODE when unset.
VITE_SENTRY_ENVIRONMENT=
